# Environment variables for Jewellery ERP Backend

# Application
APP_NAME="Jewellery ERP"
APP_VERSION="1.0.0"
DEBUG=True
SECRET_KEY=your-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Database
PAKKA_DATABASE_URL=postgresql://erp_user:erp_password@localhost:5432/pakka_db
KACHA_DATABASE_URL=postgresql://erp_user:erp_password@localhost:5432/kacha_db
SHARED_DATABASE_URL=postgresql://erp_user:erp_password@localhost:5432/shared_db

# Redis (for caching metal rates)
REDIS_URL=redis://localhost:6379

# File Storage
UPLOAD_DIR=./uploads
MAX_IMAGE_SIZE_KB=500

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# GST
GST_RATE=0.03

# AWS (for cloud deployment)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_S3_BUCKET=jewellery-erp-uploads
